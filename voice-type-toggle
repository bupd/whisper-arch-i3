#!/usr/bin/env bash

set -u

app_name="Voice Type"
model="${VOICE_TYPE_MODEL:-base.en}"
runtime_base="${XDG_RUNTIME_DIR:-/tmp}"

if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
    runtime_dir="$runtime_base/voice-type"
else
    runtime_dir="$runtime_base/voice-type-$USER"
fi

pid_file="$runtime_dir/recording.pid"
recording_file="$runtime_dir/recording.wav"
transcript_file="$runtime_dir/transcript.txt"
output_dir="$runtime_dir/whisper-output"
lock_dir="$runtime_dir/lock"

notify() {
    urgency="$1"
    timeout="$2"
    icon="$3"
    title="$4"
    body="$5"
    value="${6:-}"

    if command -v dunstify >/dev/null 2>&1; then
        if [ -n "$value" ]; then
            dunstify -a "$app_name" -u "$urgency" -t "$timeout" -i "$icon" \
                -h string:x-dunst-stack-tag:voice-type \
                -h int:value:"$value" \
                "$title" "$body"
        else
            dunstify -a "$app_name" -u "$urgency" -t "$timeout" -i "$icon" \
                -h string:x-dunst-stack-tag:voice-type \
                "$title" "$body"
        fi
    elif command -v notify-send >/dev/null 2>&1; then
        notify-send -a "$app_name" -u "$urgency" -t "$timeout" -i "$icon" "$title" "$body"
    fi
}

fail() {
    notify critical 6000 dialog-error "Voice typing failed" "$1"
    exit 1
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

cleanup_stale_pid() {
    if [ ! -f "$pid_file" ]; then
        return
    fi

    pid="$(tr -d '[:space:]' < "$pid_file")"
    if [ -z "$pid" ] || ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$pid_file"
    fi
}

start_recording() {
    require_command ffmpeg
    require_command whisper
    require_command xdotool

    mkdir -p "$runtime_dir"
    rm -f "$recording_file" "$transcript_file"
    rm -rf "$output_dir"
    mkdir -p "$output_dir"

    ffmpeg -y -hide_banner -loglevel error \
        -f pulse -i default \
        -ar 16000 -ac 1 \
        "$recording_file" >/dev/null 2>&1 &

    printf '%s\n' "$!" > "$pid_file"
    notify normal 2500 audio-input-microphone "Voice typing" "Recording... press <b>Alt+Shift+M</b> to stop" 20
}

stop_recording() {
    require_command whisper
    require_command xdotool

    pid="$(tr -d '[:space:]' < "$pid_file")"
    if [ -z "$pid" ] || ! kill -0 "$pid" 2>/dev/null; then
        rm -f "$pid_file"
        start_recording
        return
    fi

    notify low 1200 media-playback-stop "Voice typing" "Recording saved" 45
    kill -INT "$pid" 2>/dev/null || true

    count=0
    while kill -0 "$pid" 2>/dev/null && [ "$count" -lt 30 ]; do
        sleep 0.1
        count=$((count + 1))
    done

    if kill -0 "$pid" 2>/dev/null; then
        kill -TERM "$pid" 2>/dev/null || true
        sleep 0.2
    fi

    rm -f "$pid_file"

    if [ ! -s "$recording_file" ]; then
        fail "Recording file is empty"
    fi

    rm -rf "$output_dir"
    mkdir -p "$output_dir"

    notify normal 0 accessories-dictionary "Voice typing" "Transcribing with Whisper <b>$model</b>..." 70

    if ! whisper "$recording_file" \
        --model "$model" \
        --language en \
        --task transcribe \
        --fp16 False \
        --output_format txt \
        --output_dir "$output_dir" >/dev/null 2>&1; then
        fail "Whisper transcription failed"
    fi

    whisper_txt="$output_dir/$(basename "${recording_file%.*}").txt"
    if [ ! -f "$whisper_txt" ]; then
        fail "Whisper did not produce a transcript"
    fi

    tr '\n\r\t' '   ' < "$whisper_txt" | awk '{$1=$1; print}' > "$transcript_file"

    if [ ! -s "$transcript_file" ] || [ -z "$(tr -d '[:space:][:punct:]' < "$transcript_file")" ]; then
        notify normal 3500 dialog-information "Voice typing" "No speech detected"
        return
    fi

    if ! xdotool type --clearmodifiers --delay 0 --file "$transcript_file"; then
        fail "Could not type transcript with xdotool"
    fi

    notify low 2500 emblem-default "Voice typing" "Inserted transcript" 100
}

mkdir -p "$runtime_dir" || fail "Could not create runtime directory: $runtime_dir"
if ! mkdir "$lock_dir" 2>/dev/null; then
    notify normal 2500 dialog-information "Voice typing" "Already processing"
    exit 0
fi
trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT INT TERM

cleanup_stale_pid

if [ -f "$pid_file" ]; then
    stop_recording
else
    start_recording
fi
